# Copy to .env and fill in your values — NEVER commit .env to git

# MongoDB Atlas connection string (get from Atlas dashboard → Connect → Drivers)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/3mtt_compass?retryWrites=true&w=majority

# JWT secret — use a long random string in production
SECRET_KEY=replace-with-a-long-random-string-here

# Groq API key — get free at console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# Flask environment
FLASK_ENV=production
PORT=5000
